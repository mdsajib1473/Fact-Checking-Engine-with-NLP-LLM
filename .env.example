# Copy this file to `.env` and fill in real values. NEVER commit the real `.env`.
# Settings (core/settings.py) reads every secret from here via python-dotenv.

# --- Django core ---
# Generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-a-long-random-secret

# Local dev: True. Production (Render): False.
DJANGO_DEBUG=True

# Comma-separated list. Example for Render: your-app.onrender.com
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database (Neon serverless Postgres) ---
# Neon connection string. Must include ?sslmode=require (Neon requires SSL).
# Example: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Leave blank for local SQLite development.
NEON_DATABASE_URL=

# --- External APIs ---
# GROQ_API_KEY powers the verdict engine (Phase 4). Without it, every verdict
# falls back to UNVERIFIABLE with an "engine unavailable" explanation.
GROQ_API_KEY=

# --- Verdict engine (Phase 4 — all optional, sensible defaults in settings) ---
# Groq model for chain-of-thought verdict reasoning. llama-3.3-70b-versatile is
# deprecated; openai/gpt-oss-120b is the current free-tier choice.
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TIMEOUT_SECONDS=30
GROQ_MAX_TOKENS=1024
# GOOGLE_FACTCHECK_API_KEY powers the Google Fact Check Tools evidence source
# (Phase 3). Without it, that source is skipped (Wikipedia/Wikidata still run).
GOOGLE_FACTCHECK_API_KEY=

# --- Evidence retrieval (Phase 3 — all optional, sensible defaults in settings) ---
# Cache TTLs in seconds. Wikipedia/Wikidata are stable (24h); Google Fact Check
# ratings change more often (1h).
CACHE_TTL_WIKIPEDIA=86400
CACHE_TTL_WIKIDATA=86400
CACHE_TTL_GOOGLE_FACTCHECK=3600
# Hard timeout (seconds) on every outbound HTTP request.
HTTP_TIMEOUT_SECONDS=10
# Descriptive User-Agent sent to the public APIs.
PROJECT_USER_AGENT=FactCheckingEngine/0.3 (NLP-AI fact-checker; +https://github.com/mdsajib1473)
# Relevance scoring model (sentence-transformers). Set ENABLE_EMBEDDING_RELEVANCE=0
# to skip it and use a lexical token-overlap score instead (faster, lower RAM).
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ENABLE_EMBEDDING_RELEVANCE=1
# Scraper bounds: max characters kept from a fetched page, and max length of any
# single evidence snippet returned to the pipeline.
SCRAPER_MAX_CONTENT_CHARS=50000
EVIDENCE_SNIPPET_MAX_CHARS=2000
